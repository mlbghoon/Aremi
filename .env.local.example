# 키가 없어도 앱은 돌아간다 — 지도는 "간이 지도", 검색은 내장 샘플.
# 키를 넣으면 진짜 지도/검색/경로로 자동 전환된다. 발급 방법: docs/GET-KEYS.md
# .env.local 로 복사해서 값을 채운다:  cp .env.local.example .env.local

# 카카오맵 JavaScript 키 — 지도 + 장소 검색 (공개 키, 도메인 등록으로 보호)
NEXT_PUBLIC_KAKAO_JS_KEY=

# 카카오모빌리티 REST 키 — 자동차 도로 경로 (비밀, 서버 전용)
KAKAO_REST_KEY=

# ODsay 인증키 — 대중교통(지하철/버스) 길찾기 (비밀, 서버 전용)
ODSAY_KEY=

# TMap App Key — 도보(보행자) 경로 (비밀, 서버 전용)
TMAP_APP_KEY=
